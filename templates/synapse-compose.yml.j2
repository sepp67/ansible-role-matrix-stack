---
# Généré par Ansible — ne pas éditer manuellement
# Composant : {{ _synapse_container_name }} | Env : {{ environment_name }}

services:
  {{ _synapse_container_name }}:
    image: "{{ matrix_synapse_image }}:{{ matrix_synapse_version }}"
    container_name: "{{ _synapse_container_name }}"
    restart: unless-stopped
    ports:
      - "{{ docker_bind_address }}:{{ _synapse_host_port }}:8008"
{% if matrix_ca_cert_path | length > 0
   and _matrix_ca_cert_stat is defined
   and _matrix_ca_cert_stat.stat is defined
   and _matrix_ca_cert_stat.stat.exists %}
    # Entrypoint wrapper : installe la CA Caddy dans le trust store système du
    # conteneur avant de démarrer Synapse. Requis pour les connexions OIDC
    # (client HTTP Python/aiohttp, trust store différent de federation_custom_ca_list).
    entrypoint: ["/bin/sh", "/data/entrypoint.sh"]
{% endif %}
    environment:
      SYNAPSE_CONFIG_PATH: /data/homeserver.yaml
{% if matrix_extra_hosts %}
    # Résolution DNS forcée : les domaines Matrix doivent pointer vers le proxy
    # Caddy, pas vers les VMs Synapse elles-mêmes (fédération interne staging).
    extra_hosts:
{% for host, ip in matrix_extra_hosts.items() %}
      - "{{ host }}:{{ ip }}"
{% endfor %}
{% endif %}
    volumes:
      - "{{ _synapse_data_dir }}:/data"
    healthcheck:
      test: ["CMD-SHELL", "curl -fs http://localhost:8008/_matrix/client/versions || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s

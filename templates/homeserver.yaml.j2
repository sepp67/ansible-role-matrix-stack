# Généré par Ansible — ne pas éditer manuellement
# Homeserver : {{ _synapse_server_name }} | Env : {{ environment_name }}

# ── Identité du serveur ───────────────────────────────────────────────────────
server_name: "{{ _synapse_server_name }}"
public_baseurl: "{{ _synapse_public_baseurl }}"

pid_file: /data/homeserver.pid

# ── Listeners ─────────────────────────────────────────────────────────────────
# TLS terminé par le reverse proxy (Caddy) — Synapse écoute en HTTP simple.
# x_forwarded: true obligatoire pour que Synapse récupère les IPs réelles.
listeners:
  - port: 8008
    tls: false
    type: http
    x_forwarded: true
    bind_addresses: ['0.0.0.0']
    resources:
      - names: [client, federation]
        compress: false

# ── Base de données ───────────────────────────────────────────────────────────
database:
  name: psycopg2
  args:
    user: "{{ _synapse_db_user }}"
    password: "{{ _synapse_db_password }}"
    database: "{{ _synapse_db_name }}"
    host: "{{ matrix_postgres_host }}"
    port: {{ matrix_postgres_port }}
    cp_min: {{ matrix_postgres_cp_min }}
    cp_max: {{ matrix_postgres_cp_max }}

# ── Logs ──────────────────────────────────────────────────────────────────────
log_config: /data/log.config

# ── Médias ────────────────────────────────────────────────────────────────────
media_store_path: /data/media_store

# ── Secrets ───────────────────────────────────────────────────────────────────
registration_shared_secret: "{{ _synapse_registration_shared_secret }}"
macaroon_secret_key: "{{ _synapse_macaroon_secret_key }}"
form_secret: "{{ _synapse_form_secret }}"

# Clé de signature Matrix — auto-générée par Synapse au premier démarrage.
signing_key_path: "/data/{{ _synapse_server_name }}.signing.key"

# ── Inscription ───────────────────────────────────────────────────────────────
# Inscription publique désactivée : comptes créés manuellement via register_new_matrix_user.
enable_registration: false
enable_registration_without_verification: false

# ── Fédération ────────────────────────────────────────────────────────────────
{% if not matrix_federation_enabled %}
# Fédération désactivée : aucun serveur externe autorisé.
federation_domain_whitelist: []
{% endif %}

# Synapse sert lui-même les endpoints well-known sur port 8008.
# Caddy fait passer les requêtes /.well-known/matrix/* vers ce port.
serve_server_wellknown: true

trusted_key_servers:
  - server_name: "matrix.org"

# ── OIDC / Keycloak ───────────────────────────────────────────────────────────
# Désactivé par défaut. Pour activer, définir matrix_oidc_enabled: true
# et renseigner matrix_oidc_issuer, matrix_oidc_client_id ainsi que
# vault_matrix_oidc_client_secret dans le vault de l'environnement.
{% if matrix_oidc_enabled %}
oidc_providers:
  - idp_id: keycloak
    idp_name: Keycloak
    issuer: "{{ matrix_oidc_issuer }}"
    client_id: "{{ matrix_oidc_client_id }}"
    client_secret: "{{ matrix_oidc_client_secret }}"
    scopes: ["openid", "profile", "email"]
    user_mapping_provider:
      config:
        localpart_template: "{{ '{{' }} user.preferred_username {{ '}}' }}"
        display_name_template: "{{ '{{' }} user.name {{ '}}' }}"
{% endif %}

# ── Divers ────────────────────────────────────────────────────────────────────
allow_guest_access: false
presence:
  enabled: false

---
# Généré par Ansible — ne pas éditer manuellement
# Composant : matrix-postgres | Env : {{ environment_name }}

services:
  matrix-postgres:
    image: "postgres:{{ matrix_postgres_version }}"
    container_name: matrix-postgres
    restart: unless-stopped
    ports:
      - "{{ docker_bind_address }}:{{ matrix_postgres_port }}:5432"
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: "{{ matrix_postgres_superuser_password }}"
      POSTGRES_DB: postgres
      POSTGRES_HOST_AUTH_METHOD: scram-sha-256
      POSTGRES_INITDB_ARGS: "--encoding=UTF8 --locale=C --auth=scram-sha-256"
    volumes:
      - "{{ matrix_base_dir }}/postgres/data:/var/lib/postgresql/data"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 20s
